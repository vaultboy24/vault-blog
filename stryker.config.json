{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "tsconfigFile": "tsconfig.json",
  "disableTypeChecks": true,
  "incremental": true,
  "incrementalFile": "reports/mutation/stryker-incremental.json",
  "tempDirName": "stryker-tmp",
  "cleanTempDir": true,
  "dryRunTimeoutMinutes": 20,
  "timeoutMS": 10000,
  "ignoreStatic": true,
  "vitest": {
    "related": false
  },
  "reporters": ["html", "clear-text", "progress"],
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 60
  },
  "ignorePatterns": [
    ".husky",
    ".next",
    ".vscode",
    "coverage",
    "public",
    "reports",
    "stryker-tmp"
  ],
  "mutate": [
    "components/**/controller/**/*.{ts,tsx}",
    "app/hooks/**/*.{ts,tsx}",
    "app/services/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "!components/**/types.ts",
    "!components/**/index.tsx",
    "!app/utils/mocks/**",
    "!app/utils/enums/**",
    "!app/config/**"
  ],
  "mutator": {
    "excludedMutations": [
      "EqualityOperator",
      "ArrayDeclaration",
      "ObjectLiteral",
      "ConditionalExpression",
      "OptionalChaining",
      "StringLiteral",
      "BooleanLiteral",
      "NumberLiteral",
      "Regex",
      "LogicalOperator",
      "ArrowFunction",
      "MethodExpression"
    ]
  }
}

